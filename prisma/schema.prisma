// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model SiteParams {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String
  firstName    String?
  lastName     String?
  birthDate    DateTime?
  role         String        @default("user")
  street       String?
  city         String?
  postalCode   String?
  country      String?       @default("France")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reservations Reservation[]
  articles     Article[]
  uploads      Image[]
}

enum VegetableUnit {
  KG
  PIECE
}

model Vegetable {
  id        Int           @id @default(autoincrement())
  name      String        @unique
  unit      VegetableUnit @default(KG)
  price     Decimal       @db.Decimal(10, 2)
  imageUrl  String?
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  items     BasketItem[]
}

model Basket {
  id            Int           @id @default(autoincrement())
  name          String
  description   String?       @db.Text
  imageUrl      String?
  computedPrice Decimal       @default(0) @db.Decimal(10, 2)
  finalPrice    Decimal       @default(0) @db.Decimal(10, 2)
  available     Int           @default(0)
  active        Boolean       @default(true)
  position      Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         BasketItem[]
  reservations  Reservation[]
}

model BasketItem {
  id          Int       @id @default(autoincrement())
  basketId    Int
  vegetableId Int
  quantity    Decimal   @db.Decimal(10, 2)
  basket      Basket    @relation(fields: [basketId], references: [id], onDelete: Cascade)
  vegetable   Vegetable @relation(fields: [vegetableId], references: [id], onDelete: Restrict)

  @@unique([basketId, vegetableId])
  @@index([basketId])
  @@index([vegetableId])
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

enum ReservationOccurrenceStatus {
  SCHEDULED
  CANCELLED
}

enum DeliveryType {
  FARM
  PICKUP
  TOUR
}

model Reservation {
  id                  Int               @id @default(autoincrement())
  basketId            Int
  userId              Int?
  customerName        String
  email               String
  phone               String?
  message             String?           @db.Text
  status              ReservationStatus @default(PENDING)
  adminNote           String?           @db.Text
  confirmedAt         DateTime?
  deliveryType        DeliveryType?
  pickupPointId       Int?
  deliveryTourId      Int?
  deliveryAddress     String?           @db.Text
  deliveryCity        String?
  deliveryPostalCode  String?
  fulfillmentDate     DateTime?
  fulfillmentTime     String?
  fulfillmentLocation String?           @db.Text
  monthlySubscription Boolean           @default(false)
  googleCalendarEventId String?
  googleCalendarSyncedAt DateTime?
  publicActionToken   String?           @unique
  cancelledByCustomerAt DateTime?
  subscriptionActive  Boolean           @default(true)
  subscriptionCancelledAt DateTime?
  occurrences         ReservationOccurrence[]
  notifications       ReservationNotification[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  basket              Basket            @relation(fields: [basketId], references: [id], onDelete: Restrict)
  user                User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  pickupPoint         PickupPoint?      @relation(fields: [pickupPointId], references: [id], onDelete: SetNull)
  deliveryTour        DeliveryTour?     @relation(fields: [deliveryTourId], references: [id], onDelete: SetNull)

  @@index([basketId])
  @@index([userId])
  @@index([status])
  @@index([pickupPointId])
  @@index([deliveryTourId])
}

model ReservationOccurrence {
  id                 Int                         @id @default(autoincrement())
  reservationId      Int
  occurrenceDate     DateTime
  originalOccurrenceDate DateTime?
  occurrenceTime     String?
  occurrenceLocation String?                     @db.Text
  status             ReservationOccurrenceStatus @default(SCHEDULED)
  customSchedule     Boolean                     @default(false)
  cancelledAt        DateTime?
  cancellationReason String?                     @db.Text
  googleCalendarEventId String?
  lastNotifiedAt     DateTime?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  reservation        Reservation                 @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  notifications      ReservationNotification[]

  @@index([reservationId, occurrenceDate])
}

model ReservationNotification {
  id             Int                    @id @default(autoincrement())
  reservationId  Int
  occurrenceId   Int?
  kind           String
  channel        String                 @default("EMAIL")
  recipientEmail String
  subject        String
  summary        String?                @db.Text
  createdAt      DateTime               @default(now())
  reservation    Reservation            @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  occurrence     ReservationOccurrence? @relation(fields: [occurrenceId], references: [id], onDelete: SetNull)

  @@index([reservationId, createdAt])
  @@index([occurrenceId])
}

model PickupPoint {
  id              Int           @id @default(autoincrement())
  name            String
  address         String?       @db.Text
  details         String?       @db.Text
  delayDays       Int           @default(0)
  deliveryDay     Int?
  pickupStartTime String?
  openingHours    String?       @db.Text
  websiteUrl      String?
  active          Boolean       @default(true)
  position        Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  reservations    Reservation[]
}

model DeliveryTour {
  id           Int           @id @default(autoincrement())
  name         String
  dayOfWeek    Int
  startTime    String
  endTime      String
  monthlyPrice Decimal?      @db.Decimal(10, 2)
  notes        String?       @db.Text
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  cities       TourCity[]
  reservations Reservation[]
}

model TourCity {
  id          Int          @id @default(autoincrement())
  tourId      Int
  city        String
  postalCodes String?
  createdAt   DateTime     @default(now())
  tour        DeliveryTour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId])
}

model Article {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  excerpt     String?   @db.Text
  content     String    @db.LongText
  coverUrl    String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  authorId    Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  author      User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([published, publishedAt])
}

model Image {
  id           Int      @id @default(autoincrement())
  filename     String
  url          String
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  uploadedById Int?
  createdAt    DateTime @default(now())
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

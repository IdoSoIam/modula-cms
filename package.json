{
  "name": "modula-cms",
  "version": "0.1.0",
  "private": false,
  "description": "CMS modulaire Nuxt avec pages éditoriales, admin, planning et installation guidée.",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/dev-install-local.mjs",
    "dev:reset": "node ./scripts/dev-install-local.mjs --reset",
    
    "release:build": "node ./scripts/build-runtime-release.mjs",
    "release:publish": "node ./scripts/publish-runtime-release.mjs",
    "release:publish:git": "node ./scripts/publish-runtime-release-with-git.mjs",
    "registry:seed:bundled": "node ./scripts/seed-bundled-registry-templates.mjs",
    "postinstall": "node ./scripts/postinstall.mjs",

    "db:generate": "prisma generate",
    "db:migrate": "node ./scripts/apply-local-migrations.mjs",
    "db:migrate:prisma": "prisma migrate dev",
    "db:studio": "prisma studio",

    "cms:dev:cloudflare": "node ./scripts/run-platform-command.mjs cloudflare dev",
    "cms:build:cloudflare": "node ./scripts/run-platform-command.mjs cloudflare build",
    "cms:deploy:cloudflare": "node ./scripts/run-platform-command.mjs cloudflare deploy",
    "cms:db:d1:migrate:local": "node ./scripts/d1-migrate.mjs local",
    "cms:db:d1:migrate:remote": "node ./scripts/d1-migrate.mjs remote",
    "cms:db:d1:pull:prod": "node ./scripts/d1-sync.mjs d1-remote-to-local",
    "cms:db:d1:push:prod": "node ./scripts/d1-sync.mjs d1-local-to-remote",
    "cms:r2:pull:prod": "node ./scripts/r2-sync.mjs remote-to-local",
    "cms:r2:push:prod": "node ./scripts/r2-sync.mjs local-to-remote"
  },
  "dependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "@nuxt/devtools": "3.2.4",
    "@nuxt/icon": "^2.2.3",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/i18n": "^10.4.0",
    "@pinia/nuxt": "^0.11.3",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/vue-query": "^5.101.0",
    "@tiptap/extension-image": "^3.26.1",
    "@tiptap/extension-link": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@tiptap/vue-3": "^3.26.1",
    "bcryptjs": "^3.0.3",
    "daisyui": "^5.5.23",
    "dotenv": "^17.4.2",
    "nuxt": "^4.4.8",
    "pinia": "^3.0.4",
    "prisma": "^7.8.0",
    "stripe": "^22.2.1",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "nitro-cloudflare-dev": "^0.2.2",
    "wrangler": "^4.100.0"
  }
}
{
  "name": "modula-cms",
  "version": "0.1.0",
  "private": false,
  "description": "CMS modulaire Nuxt avec pages éditoriales, admin, planning et installation guidée.",
  "license": "UNLICENSED",
  "type": "module",
  "bin": {
    "modula-cms-init": "./scripts/init-host-project.mjs"
  },
  "exports": {
    "./host": "./cms/host.ts",
    "./project-config": "./shared/platform.ts",
    "./generated-project-config-template": "./templates/host/cms.project.generated.ts"
  },
  "files": [
    "assets",
    "cms",
    "components",
    "composables",
    "i18n",
    "layouts",
    "middleware",
    "migrations",
    "pages",
    "plugins",
    "prisma/client.ts",
    "prisma/schema.prisma",
    "public",
    "scripts",
    "server",
    "shared",
    "stores",
    "templates",
    "types",
    ".env.example",
    "app.vue",
    "cms.project.config.ts",
    "cms.project.generated.ts",
    "i18n.config.ts",
    "nuxt.config.ts",
    "package.json",
    "prisma.config.ts",
    "README.md",
    "worker-configuration.d.ts",
    "wrangler.jsonc"
  ],
  "scripts": {
    "dev": "node ./scripts/dev-install-local.mjs",
    "dev:reset": "node ./scripts/dev-install-local.mjs --reset",
    "build:tgz": "npm pack",
    "release:build": "node ./scripts/build-runtime-release.mjs",
    "release:publish": "node ./scripts/publish-runtime-release.mjs",
    "release:publish:git": "node ./scripts/publish-runtime-release-with-git.mjs",
    "postinstall": "node ./scripts/postinstall.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "node ./scripts/apply-local-migrations.mjs",
    "db:migrate:prisma": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "@nuxt/devtools": "3.2.4",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/i18n": "^10.2.4",
    "@pinia/nuxt": "^0.11.3",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-d1": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/vue-query": "^5.100.1",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@tiptap/vue-3": "^3.22.4",
    "bcryptjs": "^3.0.2",
    "daisyui": "^5.5.19",
    "dotenv": "^17.4.2",
    "facebook-node-sdk": "^0.2.0",
    "fb": "^2.0.0",
    "nuxt": "^4.4.2",
    "pinia": "^3.0.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/fb": "^0.0.30",
    "@types/node": "^25.6.0",
    "nitro-cloudflare-dev": "^0.2.2",
    "wrangler": "^4.95.0"
  }
}

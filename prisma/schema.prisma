// This is your Prisma schema file
generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
}

model SiteParams {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String
  firstName    String?
  lastName     String?
  birthDate    DateTime?
  role         String        @default("user")
  street       String?
  city         String?
  postalCode   String?
  country      String?       @default("France")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reservations Reservation[]
  articles     Article[]
  uploads      Image[]
}

enum VegetableUnit {
  KG
  PIECE
}

model Vegetable {
  id        Int           @id @default(autoincrement())
  name      String        @unique
  unit      VegetableUnit @default(KG)
  price     Decimal
  imageUrl  String?
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  items     BasketItem[]
}

model Basket {
  id            Int           @id @default(autoincrement())
  name          String
  description   String?
  imageUrl      String?
  computedPrice Decimal       @default(0)
  finalPrice    Decimal       @default(0)
  available     Int           @default(0)
  active        Boolean       @default(true)
  position      Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         BasketItem[]
  reservations  Reservation[]
}

model BasketItem {
  id          Int       @id @default(autoincrement())
  basketId    Int
  vegetableId Int
  quantity    Decimal
  basket      Basket    @relation(fields: [basketId], references: [id], onDelete: Cascade)
  vegetable   Vegetable @relation(fields: [vegetableId], references: [id], onDelete: Restrict)

  @@unique([basketId, vegetableId])
  @@index([basketId])
  @@index([vegetableId])
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

enum ReservationOccurrenceStatus {
  SCHEDULED
  CANCELLED
}

enum DeliveryType {
  FARM
  PICKUP
  TOUR
}

enum ReservationScheduleProposalSource {
  CUSTOMER
  ADMIN
}

model Reservation {
  id                         Int                                @id @default(autoincrement())
  basketId                   Int
  userId                     Int?
  customerName               String
  email                      String
  language                   String                             @default("fr")
  phone                      String?
  message                    String?
  status                     ReservationStatus                  @default(PENDING)
  adminNote                  String?
  confirmedAt                DateTime?
  deliveryType               DeliveryType?
  pickupPointId              Int?
  deliveryTourId             Int?
  deliveryAddress            String?
  deliveryCity               String?
  deliveryPostalCode         String?
  fulfillmentDate            DateTime?
  fulfillmentTime            String?
  fulfillmentLocation        String?
  monthlySubscription        Boolean                            @default(false)
  googleCalendarEventId      String?
  googleCalendarSyncedAt     DateTime?
  publicActionToken          String?                            @unique
  cancelledByCustomerAt      DateTime?
  subscriptionActive         Boolean                            @default(true)
  subscriptionCancelledAt    DateTime?
  archivedAt                 DateTime?
  scheduleProposalPendingBy  ReservationScheduleProposalSource?
  lastScheduleProposalAt     DateTime?
  scheduleProposalAcceptedAt DateTime?
  occurrences                ReservationOccurrence[]
  notifications              ReservationNotification[]
  scheduleProposals          ReservationScheduleProposal[]
  createdAt                  DateTime                           @default(now())
  updatedAt                  DateTime                           @updatedAt
  basket                     Basket                             @relation(fields: [basketId], references: [id], onDelete: Restrict)
  user                       User?                              @relation(fields: [userId], references: [id], onDelete: SetNull)
  pickupPoint                PickupPoint?                       @relation(fields: [pickupPointId], references: [id], onDelete: SetNull)
  deliveryTour               DeliveryTour?                      @relation(fields: [deliveryTourId], references: [id], onDelete: SetNull)

  @@index([basketId])
  @@index([userId])
  @@index([status])
  @@index([archivedAt])
  @@index([pickupPointId])
  @@index([deliveryTourId])
}

model ReservationScheduleProposal {
  id               Int                               @id @default(autoincrement())
  reservationId    Int
  proposedBy       ReservationScheduleProposalSource
  proposalDate     DateTime
  proposalTime     String
  proposalLocation String?
  acceptedAt       DateTime?
  createdAt        DateTime                          @default(now())
  updatedAt        DateTime                          @updatedAt
  reservation      Reservation                       @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@unique([reservationId, proposalDate, proposalTime], name: "ScheduleProposal_unique_date_time")
  @@index([reservationId, createdAt])
}

model ReservationOccurrence {
  id                     Int                         @id @default(autoincrement())
  reservationId          Int
  occurrenceDate         DateTime
  originalOccurrenceDate DateTime?
  occurrenceTime         String?
  occurrenceLocation     String?
  status                 ReservationOccurrenceStatus @default(SCHEDULED)
  customSchedule         Boolean                     @default(false)
  cancelledAt            DateTime?
  cancellationReason     String?
  googleCalendarEventId  String?
  lastNotifiedAt         DateTime?
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  reservation            Reservation                 @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  notifications          ReservationNotification[]

  @@index([reservationId, occurrenceDate])
}

model ReservationNotification {
  id             Int                    @id @default(autoincrement())
  reservationId  Int
  occurrenceId   Int?
  kind           String
  channel        String                 @default("EMAIL")
  recipientEmail String
  subject        String
  summary        String?
  createdAt      DateTime               @default(now())
  reservation    Reservation            @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  occurrence     ReservationOccurrence? @relation(fields: [occurrenceId], references: [id], onDelete: SetNull)

  @@index([reservationId, createdAt])
  @@index([occurrenceId])
}

model PickupPoint {
  id              Int           @id @default(autoincrement())
  name            String
  address         String?
  details         String?
  delayDays       Int           @default(0)
  deliveryDay     Int?
  pickupStartTime String?
  openingHours    String?
  websiteUrl      String?
  active          Boolean       @default(true)
  position        Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  reservations    Reservation[]
}

model DeliveryTour {
  id           Int           @id @default(autoincrement())
  name         String
  dayOfWeek    Int
  startTime    String
  endTime      String
  monthlyPrice Decimal?
  notes        String?
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  cities       TourCity[]
  reservations Reservation[]
}

model TourCity {
  id          Int          @id @default(autoincrement())
  tourId      Int
  city        String
  postalCodes String?
  createdAt   DateTime     @default(now())
  tour        DeliveryTour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId])
}

model Article {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  coverUrl    String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  authorId    Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  author      User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([published, publishedAt])
}

model Image {
  id           Int      @id @default(autoincrement())
  filename     String
  url          String
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  uploadedById Int?
  createdAt    DateTime @default(now())
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

enum CmsPageType {
  CMS
  APPLICATION
  HYBRID
}

enum CmsPageStatus {
  DRAFT
  PUBLISHED
}

enum CmsApplicationPosition {
  BEFORE_CONTENT
  AFTER_CONTENT
}

enum CmsNavigationMenu {
  PRIMARY
  FOOTER
}

enum CmsNavigationItemType {
  CMS_PAGE
  APPLICATION_ROUTE
  EXTERNAL_URL
}

model CmsPage {
  id                  Int                    @id @default(autoincrement())
  path                String                 @unique
  slug                String                 @unique
  title               String
  pageType            CmsPageType            @default(CMS)
  status              CmsPageStatus          @default(DRAFT)
  specialRole         String?
  templateKey         String                 @default("default")
  rendererKey         String?
  applicationPosition CmsApplicationPosition @default(AFTER_CONTENT)
  translationsJson    String
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  navigationItems     CmsNavigationItem[]

  @@index([status, pageType])
}

model CmsNavigationItem {
  id            Int                   @id @default(autoincrement())
  menu          CmsNavigationMenu     @default(PRIMARY)
  itemType      CmsNavigationItemType @default(CMS_PAGE)
  title         String
  labelsJson    String
  href          String
  newTab        Boolean               @default(false)
  visible       Boolean               @default(true)
  position      Int                   @default(0)
  pageId        Int?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  page          CmsPage?              @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@index([menu, visible, position])
  @@index([pageId])
}

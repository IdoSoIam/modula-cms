// This is your Prisma schema file
generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
}

model SiteParams {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String
  firstName    String?
  lastName     String?
  birthDate    DateTime?
  role         String        @default("user")
  isActive     Boolean       @default(true)
  roleId       Int?
  street       String?
  city         String?
  postalCode   String?
  country      String?       @default("France")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reservations Reservation[]
  articles     Article[]
  uploads      Image[]
  managedRole  Role?         @relation(fields: [roleId], references: [id], onDelete: SetNull)
  memberRoles  UserMemberRole[]
  createdEvents Event[]      @relation("EventCreatedBy")
  updatedEvents Event[]      @relation("EventUpdatedBy")
  publicEventReservations EventPublicReservation[]
  internalEventParticipations EventInternalParticipation[]
  passwordSetupTokens PasswordSetupToken[]

  @@index([roleId])
  @@index([isActive])
}

model PasswordSetupToken {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  userId    Int
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Role {
  id                     Int              @id @default(autoincrement())
  slug                   String           @unique
  name                   String
  description            String?
  isSystem               Boolean          @default(false)
  isDefault              Boolean          @default(false)
  specialPermissionsJson String           @default("[]")
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  users                  User[]
  permissions            RolePermission[]
}

model RolePermission {
  id        Int      @id @default(autoincrement())
  roleId     Int
  module     String
  canRead    Boolean @default(false)
  canCreate  Boolean @default(false)
  canUpdate  Boolean @default(false)
  canDelete  Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  role       Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module])
  @@index([module])
}

model MemberRole {
  id          Int                @id @default(autoincrement())
  slug        String             @unique
  name        String
  description String?
  color       String?
  isSystem    Boolean            @default(false)
  isDefault   Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  users       UserMemberRole[]
  audienceEvents EventAudienceMemberRole[]
}

model UserMemberRole {
  id           Int        @id @default(autoincrement())
  userId        Int
  memberRoleId  Int
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  memberRole    MemberRole @relation(fields: [memberRoleId], references: [id], onDelete: Cascade)

  @@unique([userId, memberRoleId])
  @@index([memberRoleId])
}

enum VegetableUnit {
  KG
  PIECE
}

model Vegetable {
  id        Int           @id @default(autoincrement())
  name      String        @unique
  unit      VegetableUnit @default(KG)
  price     Decimal
  imageUrl  String?
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  items     BasketItem[]
}

model Basket {
  id            Int           @id @default(autoincrement())
  name          String
  description   String?
  imageUrl      String?
  computedPrice Decimal       @default(0)
  finalPrice    Decimal       @default(0)
  available     Int           @default(0)
  active        Boolean       @default(true)
  position      Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         BasketItem[]
  reservations  Reservation[]
}

model BasketItem {
  id          Int       @id @default(autoincrement())
  basketId    Int
  vegetableId Int
  quantity    Decimal
  basket      Basket    @relation(fields: [basketId], references: [id], onDelete: Cascade)
  vegetable   Vegetable @relation(fields: [vegetableId], references: [id], onDelete: Restrict)

  @@unique([basketId, vegetableId])
  @@index([basketId])
  @@index([vegetableId])
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

enum ReservationOccurrenceStatus {
  SCHEDULED
  CANCELLED
}

enum DeliveryType {
  FARM
  PICKUP
  TOUR
}

enum ReservationScheduleProposalSource {
  CUSTOMER
  ADMIN
}

model Reservation {
  id                         Int                                @id @default(autoincrement())
  basketId                   Int
  userId                     Int?
  customerName               String
  email                      String
  language                   String                             @default("fr")
  phone                      String?
  message                    String?
  status                     ReservationStatus                  @default(PENDING)
  adminNote                  String?
  confirmedAt                DateTime?
  deliveryType               DeliveryType?
  pickupPointId              Int?
  deliveryTourId             Int?
  deliveryAddress            String?
  deliveryCity               String?
  deliveryPostalCode         String?
  fulfillmentDate            DateTime?
  fulfillmentTime            String?
  fulfillmentLocation        String?
  monthlySubscription        Boolean                            @default(false)
  googleCalendarEventId      String?
  googleCalendarSyncedAt     DateTime?
  publicActionToken          String?                            @unique
  cancelledByCustomerAt      DateTime?
  subscriptionActive         Boolean                            @default(true)
  subscriptionCancelledAt    DateTime?
  archivedAt                 DateTime?
  scheduleProposalPendingBy  ReservationScheduleProposalSource?
  lastScheduleProposalAt     DateTime?
  scheduleProposalAcceptedAt DateTime?
  occurrences                ReservationOccurrence[]
  notifications              ReservationNotification[]
  scheduleProposals          ReservationScheduleProposal[]
  createdAt                  DateTime                           @default(now())
  updatedAt                  DateTime                           @updatedAt
  basket                     Basket                             @relation(fields: [basketId], references: [id], onDelete: Restrict)
  user                       User?                              @relation(fields: [userId], references: [id], onDelete: SetNull)
  pickupPoint                PickupPoint?                       @relation(fields: [pickupPointId], references: [id], onDelete: SetNull)
  deliveryTour               DeliveryTour?                      @relation(fields: [deliveryTourId], references: [id], onDelete: SetNull)

  @@index([basketId])
  @@index([userId])
  @@index([status])
  @@index([archivedAt])
  @@index([pickupPointId])
  @@index([deliveryTourId])
}

model ReservationScheduleProposal {
  id               Int                               @id @default(autoincrement())
  reservationId    Int
  proposedBy       ReservationScheduleProposalSource
  proposalDate     DateTime
  proposalTime     String
  proposalLocation String?
  acceptedAt       DateTime?
  createdAt        DateTime                          @default(now())
  updatedAt        DateTime                          @updatedAt
  reservation      Reservation                       @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@unique([reservationId, proposalDate, proposalTime], name: "ScheduleProposal_unique_date_time")
  @@index([reservationId, createdAt])
}

model ReservationOccurrence {
  id                     Int                         @id @default(autoincrement())
  reservationId          Int
  occurrenceDate         DateTime
  originalOccurrenceDate DateTime?
  occurrenceTime         String?
  occurrenceLocation     String?
  status                 ReservationOccurrenceStatus @default(SCHEDULED)
  customSchedule         Boolean                     @default(false)
  cancelledAt            DateTime?
  cancellationReason     String?
  googleCalendarEventId  String?
  lastNotifiedAt         DateTime?
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  reservation            Reservation                 @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  notifications          ReservationNotification[]

  @@index([reservationId, occurrenceDate])
}

model ReservationNotification {
  id             Int                    @id @default(autoincrement())
  reservationId  Int
  occurrenceId   Int?
  kind           String
  channel        String                 @default("EMAIL")
  recipientEmail String
  subject        String
  summary        String?
  createdAt      DateTime               @default(now())
  reservation    Reservation            @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  occurrence     ReservationOccurrence? @relation(fields: [occurrenceId], references: [id], onDelete: SetNull)

  @@index([reservationId, createdAt])
  @@index([occurrenceId])
}

model PickupPoint {
  id              Int           @id @default(autoincrement())
  name            String
  address         String?
  details         String?
  delayDays       Int           @default(0)
  deliveryDay     Int?
  pickupStartTime String?
  openingHours    String?
  websiteUrl      String?
  active          Boolean       @default(true)
  position        Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  reservations    Reservation[]
}

model DeliveryTour {
  id           Int           @id @default(autoincrement())
  name         String
  dayOfWeek    Int
  startTime    String
  endTime      String
  monthlyPrice Decimal?
  notes        String?
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  cities       TourCity[]
  reservations Reservation[]
}

model TourCity {
  id          Int          @id @default(autoincrement())
  tourId      Int
  city        String
  postalCodes String?
  createdAt   DateTime     @default(now())
  tour        DeliveryTour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId])
}

model Article {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  coverUrl    String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  authorId    Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  author      User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([published, publishedAt])
}

model Image {
  id           Int      @id @default(autoincrement())
  filename     String
  url          String
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  uploadedById Int?
  createdAt    DateTime @default(now())
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  variants     ImageVariant[]
  usages       ImageUsage[]

  @@index([createdAt])
}

model ImageVariant {
  id         Int      @id @default(autoincrement())
  imageId    Int
  storageKey String   @unique
  mimeType   String
  size       Int
  width      Int?
  height     Int?
  fit        String?
  quality    Int?
  format     String
  createdAt  DateTime @default(now())
  image      Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@unique([imageId, width, height, fit, quality, format], name: "ImageVariant_unique_signature")
  @@index([imageId, createdAt])
}

model ImageUsage {
  id        Int      @id @default(autoincrement())
  imageId   Int
  scopeType String
  scopeId   String
  fieldKey  String
  label     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  image     Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@unique([imageId, scopeType, scopeId, fieldKey], name: "ImageUsage_unique_scope")
  @@index([imageId, scopeType])
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  CANCELLED
}

enum EventVisibility {
  PUBLIC
  PRIVATE
}

enum EventApprovalMode {
  AUTO
  MANUAL
}

enum EventPublicReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REJECTED
}

enum EventInternalParticipationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REJECTED
}

enum EventKind {
  EVENT
  PERMANENCE
}

enum EventRecurrenceType {
  NONE
  WEEKLY
}

enum EventOccurrenceStatus {
  SCHEDULED
  CANCELLED
}

model Event {
  id                               Int                            @id @default(autoincrement())
  slug                             String                         @unique
  kind                             EventKind                      @default(EVENT)
  status                           EventStatus                    @default(DRAFT)
  visibility                       EventVisibility                @default(PUBLIC)
  startsAt                         DateTime
  endsAt                           DateTime?
  recurrenceType                   EventRecurrenceType            @default(NONE)
  recurrenceDaysJson               String                         @default("[]")
  recurrenceStartDate              DateTime?
  recurrenceEndDate                DateTime?
  recurrenceStartTime              String?
  recurrenceEndTime                String?
  placeName                        String?
  placeAddress                     String?
  placeCity                        String?
  mapUrl                           String?
  coverImageUrl                    String?
  galleryJson                      String                         @default("[]")
  publicCapacity                   Int?
  internalCapacity                 Int?
  publicReservationEnabled         Boolean                        @default(false)
  internalParticipationEnabled     Boolean                        @default(false)
  internalParticipationApprovalMode EventApprovalMode             @default(MANUAL)
  internalParticipationInfo        String?
  notifyAdminOnInternalParticipation Boolean                      @default(true)
  translationsJson                 String
  createdById                      Int?
  updatedById                      Int?
  createdAt                        DateTime                       @default(now())
  updatedAt                        DateTime                       @updatedAt
  createdBy                        User?                          @relation("EventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy                        User?                          @relation("EventUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  audienceMemberRoles              EventAudienceMemberRole[]
  publicReservations               EventPublicReservation[]
  internalParticipations           EventInternalParticipation[]
  occurrences                      EventOccurrence[]

  @@index([kind, status, startsAt])
  @@index([status, startsAt])
  @@index([visibility, startsAt])
  @@index([createdById])
  @@index([updatedById])
}

model EventOccurrence {
  id                                Int                   @id @default(autoincrement())
  eventId                            Int
  occurrenceDate                     DateTime
  startsAt                           DateTime
  endsAt                             DateTime?
  status                             EventOccurrenceStatus @default(SCHEDULED)
  isOverride                         Boolean              @default(false)
  titleOverride                      String?
  subtitleOverride                   String?
  excerptOverride                    String?
  contentOverrideJson                String?
  placeNameOverride                  String?
  placeAddressOverride               String?
  placeCityOverride                  String?
  mapUrlOverride                     String?
  coverImageOverrideUrl              String?
  publicCapacityOverride             Int?
  internalCapacityOverride           Int?
  internalParticipationInfoOverride  String?
  createdAt                          DateTime             @default(now())
  updatedAt                          DateTime             @updatedAt
  event                              Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, occurrenceDate])
  @@index([occurrenceDate, status])
  @@index([eventId, startsAt])
}

model EventAudienceMemberRole {
  id        Int      @id @default(autoincrement())
  eventId    Int
  memberRoleId Int
  createdAt  DateTime @default(now())
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  memberRole MemberRole @relation(fields: [memberRoleId], references: [id], onDelete: Cascade)

  @@unique([eventId, memberRoleId])
  @@index([memberRoleId])
}

model EventPublicReservation {
  id            Int                          @id @default(autoincrement())
  eventId        Int
  userId         Int?
  customerName   String
  email          String
  phone          String?
  seats          Int                          @default(1)
  message        String?
  status         EventPublicReservationStatus @default(PENDING)
  adminNote      String?
  confirmedAt    DateTime?
  cancelledAt    DateTime?
  rejectedAt     DateTime?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  event          Event                        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User?                        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventId, status, createdAt])
  @@index([userId])
}

model EventInternalParticipation {
  id            Int                              @id @default(autoincrement())
  eventId        Int
  userId         Int
  message        String?
  status         EventInternalParticipationStatus @default(PENDING)
  adminNote      String?
  confirmedAt    DateTime?
  cancelledAt    DateTime?
  rejectedAt     DateTime?
  createdAt      DateTime                         @default(now())
  updatedAt      DateTime                         @updatedAt
  event          Event                            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User                             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([status, createdAt])
  @@index([userId])
}

enum CmsPageType {
  CMS
  APPLICATION
  HYBRID
}

enum CmsPageStatus {
  DRAFT
  PUBLISHED
}

enum CmsApplicationPosition {
  BEFORE_CONTENT
  AFTER_CONTENT
}

enum CmsNavigationMenu {
  PRIMARY
  FOOTER
}

enum CmsNavigationItemType {
  CMS_PAGE
  APPLICATION_ROUTE
  EXTERNAL_URL
}

model CmsPage {
  id                  Int                    @id @default(autoincrement())
  path                String                 @unique
  slug                String                 @unique
  title               String
  pageType            CmsPageType            @default(CMS)
  status              CmsPageStatus          @default(DRAFT)
  specialRole         String?
  templateKey         String                 @default("default")
  rendererKey         String?
  applicationPosition CmsApplicationPosition @default(AFTER_CONTENT)
  translationsJson    String
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  navigationItems     CmsNavigationItem[]

  @@index([status, pageType])
}

model CmsNavigationItem {
  id            Int                   @id @default(autoincrement())
  menu          CmsNavigationMenu     @default(PRIMARY)
  itemType      CmsNavigationItemType @default(CMS_PAGE)
  title         String
  labelsJson    String
  href          String
  newTab        Boolean               @default(false)
  visible       Boolean               @default(true)
  position      Int                   @default(0)
  pageId        Int?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  page          CmsPage?              @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@index([menu, visible, position])
  @@index([pageId])
}

{
  "name": "modula-cms",
  "version": "0.1.38",
  "private": false,
  "description": "CMS modulaire Nuxt avec pages éditoriales, admin et installation guidée.",
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/dev-install-local.mjs",
    "dev:reset": "node ./scripts/dev-install-local.mjs --reset",
    "postinstall": "node ./scripts/postinstall.mjs",
    "release:build": "node ./scripts/build-runtime-release.mjs",
    "release:publish": "node ./scripts/publish-runtime-release.mjs",
    "release:publish:git": "node ./scripts/publish-runtime-release-with-git.mjs",
    "registry:seed:bundled": "node ./scripts/seed-bundled-registry-templates.mjs",
    "db:generate:internal": "node --experimental-strip-types ./generator/generate-db-artifacts.ts",
    "db:migrate:status": "node --experimental-strip-types ./scripts/db-migrate.mjs sqlite --status",
    "db:migrate:scaffold": "node --experimental-strip-types ./scripts/db-migration-scaffold.mjs",
    "db:migrate": "node --experimental-strip-types ./scripts/db-migrate.mjs sqlite",
    "cms:dev:cloudflare": "node ./scripts/run-platform-command.mjs cloudflare dev",
    "cms:build:cloudflare": "node ./scripts/run-platform-command.mjs cloudflare build",
    "cms:deploy:cloudflare": "node ./scripts/run-platform-command.mjs cloudflare deploy",
    "cms:db:d1:migrate:local": "node --experimental-strip-types ./scripts/db-migrate.mjs d1 local",
    "cms:db:d1:migrate:remote": "node --experimental-strip-types ./scripts/db-migrate.mjs d1 remote",
    "cms:db:d1:migrate:status:local": "node --experimental-strip-types ./scripts/db-migrate.mjs d1 local --status",
    "cms:db:d1:migrate:status:remote": "node --experimental-strip-types ./scripts/db-migrate.mjs d1 remote --status",
    "cms:db:d1:pull:prod": "node ./scripts/d1-sync.mjs d1-remote-to-local",
    "cms:db:d1:push:prod": "node ./scripts/d1-sync.mjs d1-local-to-remote",
    "cms:r2:pull:prod": "node ./scripts/r2-sync.mjs remote-to-local",
    "cms:r2:push:prod": "node ./scripts/r2-sync.mjs local-to-remote"
  },
  "dependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "@nuxt/devtools": "3.2.4",
    "@nuxt/icon": "^2.2.3",
    "@nuxt/image": "^2.0.0",
    "@pinia/nuxt": "^0.11.3",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/vue-query": "^5.101.0",
    "@tiptap/extension-image": "^3.26.1",
    "@tiptap/extension-link": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@tiptap/vue-3": "^3.26.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "daisyui": "^5.5.23",
    "dotenv": "^17.4.2",
    "nuxt": "^4.4.8",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "nitro-cloudflare-dev": "^0.2.2",
    "playwright-core": "^1.61.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.100.0"
  }
}

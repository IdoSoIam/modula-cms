// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model SiteParams {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String
  firstName    String?
  lastName     String?
  birthDate    DateTime?
  role         String        @default("user")
  street       String?
  city         String?
  postalCode   String?
  country      String?       @default("France")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reservations Reservation[]
}

enum VegetableUnit {
  KG
  PIECE
}

model Vegetable {
  id        Int           @id @default(autoincrement())
  name      String        @unique
  unit      VegetableUnit @default(KG)
  price     Decimal       @db.Decimal(10, 2)
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  items     BasketItem[]
}

model Basket {
  id            Int           @id @default(autoincrement())
  name          String
  description   String?       @db.Text
  imageUrl      String?
  computedPrice Decimal       @default(0) @db.Decimal(10, 2)
  finalPrice    Decimal       @default(0) @db.Decimal(10, 2)
  available     Int           @default(0)
  active        Boolean       @default(true)
  position      Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         BasketItem[]
  reservations  Reservation[]
}

model BasketItem {
  id          Int       @id @default(autoincrement())
  basketId    Int
  vegetableId Int
  quantity    Decimal   @db.Decimal(10, 2)
  basket      Basket    @relation(fields: [basketId], references: [id], onDelete: Cascade)
  vegetable   Vegetable @relation(fields: [vegetableId], references: [id], onDelete: Restrict)

  @@unique([basketId, vegetableId])
  @@index([basketId])
  @@index([vegetableId])
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

model Reservation {
  id           Int               @id @default(autoincrement())
  basketId     Int
  userId       Int?
  customerName String
  email        String
  phone        String?
  message      String?           @db.Text
  status       ReservationStatus @default(PENDING)
  adminNote    String?           @db.Text
  confirmedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  basket       Basket            @relation(fields: [basketId], references: [id], onDelete: Restrict)
  user         User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([basketId])
  @@index([userId])
  @@index([status])
}
